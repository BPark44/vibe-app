# ---------------------------------------------------------------------------
# Supabase Auth (client-side) — found in Project Settings > API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Public site URL (used by the tRPC client on the server). Optional in dev.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Database (used by Kysely at runtime and Prisma for migrations)
# Found in Project Settings > Database > Connection string.
#
# DATABASE_URL  -> "Transaction" pooler (port 6543), used by the running app.
# DIRECT_URL    -> "Direct connection"  (port 5432), used by Prisma migrate.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"
